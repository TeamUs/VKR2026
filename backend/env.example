# =====================================================
# POIZONIC MINI APP / ВКР MINI APP - ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ
# =====================================================
#
# ИНСТРУКЦИЯ: 
# 1. Скопируйте этот файл как .env
# 2. Заполните все переменные ниже реальными значениями
# 3. Обязательные переменные помечены как (ОБЯЗАТЕЛЬНО)
#
# ---------- Деплой ВКР на сервере (под путём /vkr) ----------
# На сервере в backend/.env укажите:
#   BOT_TOKEN=токен_от_BotFather_для_бота_ВКР  (не коммитить!)
#   PORT=3001
#   FRONTEND_URL=https://poizonic.ru/vkr/
#   DB_NAME=default_db  (та же БД, что и основное приложение)
#   CORS_ORIGINS=https://poizonic.ru
# Остальные DB_*, MANAGER_TELEGRAM_ID — как для основного приложения.
#
# =====================================================
# TELEGRAM BOT
# =====================================================

# Токен Telegram бота (ОБЯЗАТЕЛЬНО). Для ВКР — токен бота ВКР из BotFather
BOT_TOKEN=your_telegram_bot_token_here

# ID менеджера для уведомлений (ОБЯЗАТЕЛЬНО)
# Ежедневные отчеты, уведомления о новых заказах, сбоях сервера и БД
MANAGER_TELEGRAM_ID=7696515351

# ID администратора для админ-панели (не используется в текущей версии)
ADMIN_TELEGRAM_ID=690296532

# Канал для публикации отзывов
REVIEWS_CHANNEL_ID=-1002499442701

# =====================================================
# БАЗА ДАННЫХ (ОБЯЗАТЕЛЬНО)
# =====================================================
DB_HOST=your_database_host_here
DB_USER=your_database_user_here
DB_PASSWORD=your_database_password_here
DB_NAME=your_database_name_here
DB_PORT=3306

# =====================================================
# СЕРВЕР
# =====================================================
PORT=3000

# ВАЖНО: Установите NODE_ENV=production для продакшена!
# Для локальной разработки используйте NODE_ENV=development
NODE_ENV=production

# ВАЖНО ДЛЯ PRODUCTION: Используйте реальный домен!
# НЕ используйте localhost в production - сервер не запустится!
# Пример для production (основное приложение): https://poizonic.ru
# Для ВКР (второе приложение): https://poizonic.ru/vkr/
# Пример для development: http://localhost:3001
FRONTEND_URL=https://poizonic.ru

# =====================================================
# КУРСЫ ВАЛЮТ (ЦБ РФ)
# =====================================================
# Источник курса: Центральный банк РФ
CBR_API_URL=https://www.cbr-xml-daily.ru/daily_json.js
EXCHANGE_RATE_UPDATE_INTERVAL=3600000

# =====================================================
# БИЗНЕС НАСТРОЙКИ
# =====================================================
# Комиссии в рублях (не в процентах!)
DEFAULT_COMMISSION_RUB=1000
REFERRAL_COMMISSION_RUB=400
DELIVERY_COST_PER_KG_RUB=800

# РЕЗЕРВНЫЙ курс CNY/RUB (используется ТОЛЬКО если ЦБ РФ недоступен)
# ВНИМАНИЕ: Основной курс всегда берется с ЦБ РФ!
DEFAULT_EXCHANGE_RATE=12.5

# =====================================================
# РЕФЕРАЛЬНАЯ СИСТЕМА
# =====================================================
REFERRAL_DISCOUNT_DAYS=14
REFERRER_BONUS_DAYS=7

# =====================================================
# БЕЗОПАСНОСТЬ
# =====================================================
# ВАЖНО: Измените JWT_SECRET на случайную строку в production!
JWT_SECRET=your_very_secret_jwt_key_change_in_production

# CORS - для production используйте реальные домены!
# НЕ используйте localhost в production!
# Пример для production: https://poizonic.ru,https://web.telegram.org
# Пример для development: http://localhost:3000,http://localhost:3001
CORS_ORIGINS=https://poizonic.ru,https://www.poizonic.ru,https://web.telegram.org,https://webk.telegram.org,https://webz.telegram.org

# =====================================================
# ЛОГИРОВАНИЕ
# =====================================================
LOG_LEVEL=info
ENABLE_CONSOLE_LOGS=true
ENABLE_FILE_LOGS=false

# =====================================================
# УВЕДОМЛЕНИЯ
# =====================================================
ENABLE_TELEGRAM_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# =====================================================
# ФАЙЛЫ И ЗАГРУЗКИ
# =====================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880